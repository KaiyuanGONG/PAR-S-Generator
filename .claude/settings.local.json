 ──\nnb['cells'][13]['source'] = [\n    \"# \\\\u2500\\\\u2500 \\\\u03bc-map \\\\u6784\\\\u5efa \\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\n\",\n    \"mu = np.ones\\(shape, dtype=np.float32\\) * CFG['mu_water']\\\\n\",\n    \"\\\\n\",\n    \"# \\\\u80ba -- \\\\u4e2d\\\\u5fc3 Z=0.38 \\(10.8cm \\\\u4e0a\\\\u65b9\\), \\\\u80ba\\\\u9876 Z=0.58 < \\\\u4f53\\\\u5185\\\\u9876 Z=0.69\\\\n\",\n    \"lung_r = create_ellipsoid\\(shape, \\(0.38,  0.05, -0.22\\), \\(0.20, 0.14, 0.18\\)\\)\\\\n\",\n    \"lung_l = create_ellipsoid\\(shape, \\(0.38,  0.05,  0.22\\), \\(0.20, 0.14, 0.18\\)\\)\\\\n\",\n    \"mu[lung_r | lung_l] = CFG['mu_lung']\\\\n\",\n    \"\\\\n\",\n    \"# \\\\u810a\\\\u67f1 -- Y=-0.30 \\(8.5cm \\\\u540e\\\\u65b9\\), \\\\u76f4\\\\u5f84 3.4cm\\\\n\",\n    \"Z_grid, Y_grid, X_grid = get_grid\\(shape\\)\\\\n\",\n    \"spine_mask = \\(\\(X_grid - 0\\)**2 + \\(Y_grid + 0.30\\)**2\\) <= 0.06**2\\\\n\",\n    \"mu[spine_mask] = CFG['mu_spine']\\\\n\",\n    \"\\\\n\",\n    \"# \\\\u809d\\\\u810f\\\\n\",\n    \"mu[liver] = CFG['mu_liver']\\\\n\",\n    \"\\\\n\",\n    \"# \\\\u8154\\\\u58c1\\\\u8102\\\\u80aa\\\\u5c42 -- outer_body=\\(0.69,0.41,0.62\\), body_inner=\\(0.67,0.39,0.60\\)\\\\n\",\n    \"outer_body = create_ellipsoid\\(shape, \\(0,0,0\\), \\(0.69, 0.41, 0.62\\)\\)\\\\n\",\n    \"body_inner = create_ellipsoid\\(shape, \\(0,0,0\\), \\(0.67, 0.39, 0.60\\)\\)\\\\n\",\n    \"fat_layer  = outer_body & ~body_inner\\\\n\",\n    \"mu[fat_layer] = CFG['mu_fat']\\\\n\",\n    \"\\\\n\",\n    \"# \\\\u7eb9\\\\u7406\\\\u566a\\\\u58f0\\\\n\",\n    \"noise = gaussian_filter\\(rng.random\\(shape\\).astype\\(np.float32\\), sigma=CFG['mu_noise_sigma']\\)\\\\n\",\n    \"noise = \\(noise - noise.mean\\(\\)\\) * CFG['mu_noise_amp']\\\\n\",\n    \"mu    = np.clip\\(mu + noise, 0, None\\)\\\\n\",\n    \"\\\\n\",\n    \"# \\\\u7a7a\\\\u6c14\\\\uff1a\\\\u4f53\\\\u5916\\\\u4f53\\\\u7d20\\\\u5fc5\\\\u987b\\\\u4e3a 0.0\\\\n\",\n    \"mu[~outer_body] = 0.0\\\\n\",\n    \"\\\\n\",\n    \"print\\('\\\\u03bc-map \\\\u6784\\\\u5efa\\\\u5b8c\\\\u6210 \\(v2.2 \\\\u4fee\\\\u6b63\\\\u4f53\\\\u578b\\)'\\)\\\\n\",\n    \"print\\(f'  \\\\u7a7a\\\\u6c14\\\\u5360\\\\u6bd4: {\\(mu==0\\).sum\\(\\)/mu.size:.1%}  \\(\\\\u5e94 >50%\\)'\\)\\\\n\",\n    \"print\\(f'  \\\\u4f53\\\\u5185\\\\u4f53\\\\u7d20: {\\(mu>0\\).sum\\(\\):,}  \\({\\(mu>0\\).sum\\(\\)*\\(4.42/10\\)**3:.0f} ml\\)'\\)\\\\n\",\n    \"print\\(f'  mu \\\\u8303\\\\u56f4: [{mu[mu>0].min\\(\\):.4f}, {mu.max\\(\\):.4f}] cm\\\\u207b\\\\u00b9'\\)\\\\n\"\n]\n\n# ── Cell 37: update validation \\(B.1\\) ──\nnb['cells'][37]['source'] = [\n    \"# \\\\u2500\\\\u2500 B.1 \\\\u89e3\\\\u5256\\\\u5408\\\\u7406\\\\u6027\\\\u9a8c\\\\u8bc1 + \\\\u6563\\\\u5c04\\\\u98ce\\\\u9669\\\\u8bc4\\\\u4f30 \\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\u2500\\\\n\",\n    \"print\\('=' * 60\\)\\\\n\",\n    \"print\\('STAGE 1 \\\\u9a8c\\\\u8bc1\\\\uff1a\\\\u4f53\\\\u6a21\\\\u89e3\\\\u5256\\\\u5408\\\\u7406\\\\u6027'\\)\\\\n\",\n    \"print\\('=' * 60\\)\\\\n\",\n    \"\\\\n\",\n    \"results_stage1 = {}\\\\n\",\n    \"HALF_FOV = 128 * 4.42 / 2 / 10   # cm\\\\n\",\n    \"vox_vol_ml = \\(4.42 / 10\\) ** 3\\\\n\",\n    \"\\\\n\",\n    \"# 1. \\\\u8eab\\\\u4f53\\\\u5c3a\\\\u5bf8\\\\n\",\n    \"z_cm = \\(mu>0\\).any\\(axis=\\(1,2\\)\\).sum\\(\\) * 4.42/10\\\\n\",\n    \"y_cm = \\(mu>0\\).any\\(axis=\\(0,2\\)\\).sum\\(\\) * 4.42/10\\\\n\",\n    \"x_cm = \\(mu>0\\).any\\(axis=\\(0,1\\)\\).sum\\(\\) * 4.42/10\\\\n\",\n    \"body_ok = \\(28<=z_cm<=45\\) and \\(15<=y_cm<=30\\) and \\(25<=x_cm<=42\\)\\\\n\",\n    \"s = 'OK' if body_ok else 'FAIL'\\\\n\",\n    \"print\\(f'[{s}] \\\\u8eab\\\\u4f53\\\\u5c3a\\\\u5bf8: Z={z_cm:.1f}cm SI  Y={y_cm:.1f}cm AP  X={x_cm:.1f}cm LR'\\)\\\\n\",\n    \"print\\(f'      \\\\u76ee\\\\u6807: Z=28-45  Y=15-30  X=25-42 cm'\\)\\\\n\",\n    \"results_stage1['body_size'] = body_ok\\\\n\",\n    \"\\\\n\",\n    \"# 2. \\\\u7a7a\\\\u6c14\\\\u5360\\\\u6bd4 -- \\\\u76f4\\\\u63a5\\\\u5f71\\\\u54cd\\\\u6563\\\\u5c04\\\\u6bd4\\\\u4f8b\\\\n\",\n    \"air_frac = \\(mu==0\\).sum\\(\\) / mu.size\\\\n\",\n    \"air_ok = air_frac >= 0.50\\\\n\",\n    \"s = 'OK' if air_ok else 'FAIL'\\\\n\",\n    \"print\\(f'[{s}] \\\\u7a7a\\\\u6c14\\\\u5360\\\\u6bd4: {air_frac:.1%}  \\(\\\\u5e94>=50%\\)'\\)\\\\n\",\n    \"print\\(f'     [\\\\u6563\\\\u5c04\\\\u98ce\\\\u9669] \\\\u4f53\\\\u5916\\\\u4e3a\\\\u7a7a\\\\u6c14\\(\\\\u03bc=0\\)\\\\u5bf9\\\\u964d\\\\u4f4e\\\\u6563\\\\u5c04\\\\u81f3\\\\u5173\\\\u91cd\\\\u8981\\\\uff01'\\)\\\\n\",\n    \"results_stage1['air_fraction'] = air_ok\\\\n\",\n    \"\\\\n\",\n    \"# 3. \\\\u809d\\\\u810f\\\\u4f53\\\\u79ef\\\\n\",\n    \"liver_vol = liver.sum\\(\\) * vox_vol_ml\\\\n\",\n    \"vol_ok = 900 <= liver_vol <= 1900\\\\n\",\n    \"s = 'OK' if vol_ok else 'FAIL'\\\\n\",\n    \"print\\(f'[{s}] \\\\u809d\\\\u810f\\\\u4f53\\\\u79ef: {liver_vol:.0f} mL  \\(\\\\u6b63\\\\u5e38: 900-1900 mL\\)'\\)\\\\n\",\n    \"results_stage1['liver_vol'] = vol_ok\\\\n\",\n    \"\\\\n\",\n    \"# 4. \\\\u5de6\\\\u53f6\\\\u6bd4\\\\u4f8b\\\\n\",\n    \"left_ratio = left_mask.sum\\(\\) / max\\(liver.sum\\(\\), 1\\)\\\\n\",\n    \"lr_ok = 0.22 <= left_ratio <= 0.48\\\\n\",\n    \"s = 'OK' if lr_ok else 'FAIL'\\\\n\",\n    \"print\\(f'[{s}] \\\\u5de6\\\\u53f6\\\\u6bd4\\\\u4f8b: {left_ratio:.1%}  \\(\\\\u6b63\\\\u5e38: 22-48%\\)'\\)\\\\n\",\n    \"results_stage1['left_ratio'] = lr_ok\\\\n\",\n    \"\\\\n\",\n    \"# 5. \\\\u80ba\\\\u5728\\\\u809d\\\\u810f\\\\u4e0a\\\\u65b9\\\\n\",\n    \"half_z = shape[0]//2\\\\n\",\n    \"lung_up = \\(\\(mu[half_z:,:,:]>0.03\\)&\\(mu[half_z:,:,:]<0.07\\)\\).sum\\(\\)\\\\n\",\n    \"lung_lo = \\(\\(mu[:half_z,:,:]>0.03\\)&\\(mu[:half_z,:,:]<0.07\\)\\).sum\\(\\)\\\\n\",\n    \"lung_ok = lung_up > 500 and lung_lo == 0\\\\n\",\n    \"s = 'OK' if lung_ok else 'FAIL'\\\\n\",\n    \"print\\(f'[{s}] \\\\u80ba\\\\u4f4d\\\\u7f6e: \\\\u4e0a\\\\u534a\\\\u533a={lung_up}\\\\u4f53\\\\u7d20  \\\\u4e0b\\\\u534a\\\\u533a={lung_lo}\\\\u4f53\\\\u7d20  \\(\\\\u80fa\\\\u5e94\\\\u5168\\\\u5728\\\\u4e0a\\\\u534a\\\\u533a\\)'\\)\\\\n\",\n    \"results_stage1['lung_position'] = lung_ok\\\\n\",\n    \"\\\\n\",\n    \"# 6. mu \\\\u7ec4\\\\u7ec7\\\\u503c\\\\n\",\n    \"mu_ok = True\\\\n\",\n    \"nz = mu[mu>0]\\\\n\",\n    \"print\\(f'[OK] \\\\u03bc\\\\u6700\\\\u5c0f\\(>0\\): {nz.min\\(\\):.4f}  \\\\u03bc\\\\u6700\\\\u5927: {nz.max\\(\\):.4f}  \\\\u5747\\\\u5503: {nz.mean\\(\\):.4f} cm\\\\u207b\\\\u00b9'\\)\\\\n\",\n    \"results_stage1['mu_range'] = True\\\\n\",\n    \"\\\\n\",\n    \"# 7. \\\\u6563\\\\u5c04\\\\u98ce\\\\u9669\\\\u5f39\\\\u5fc3\\\\u8bc4\\\\u4f30\\\\n\",\n    \"print\\(\\)\\\\n\",\n    \"print\\('--- \\\\u6563\\\\u5c04\\\\u98ce\\\\u9669\\\\u8bc4\\\\u4f30 \\(Scatter/Total \\\\u9884\\\\u6d4b\\) ---'\\)\\\\n\",\n    \"body_vol_ml = \\(mu>0\\).sum\\(\\) * vox_vol_ml\\\\n\",\n    \"print\\(f'  \\\\u4f53\\\\u6a21\\\\u4f53\\\\u79ef: {body_vol_ml:.0f} ml = {body_vol_ml/1000:.1f} L'\\)\\\\n\",\n    \"SCATTER_RISK = 'LOW' if body_vol_ml < 25000 else \\('MED' if body_vol_ml < 35000 else 'HIGH'\\)\\\\n\",\n    \"print\\(f'  \\\\u6563\\\\u5c04\\\\u98ce\\\\u9669: {SCATTER_RISK}  \\(>35L=HIGH, 25-35L=MED, <25L=LOW\\)'\\)\\\\n\",\n    \"print\\(f'  \\\\u7a7a\\\\u6c14\\\\u5360\\\\u6bd4: {air_frac:.1%}  \\(>80%\\\\u65f6\\\\u6563\\\\u5c04\\\\u60a8\\\\u8fd1\\\\u6b63\\\\u5e38\\)'\\)\\\\n\",\n    \"\\\\n\",\n    \"# \\\\u6c47\\\\u603b\\\\n\",\n    \"n_pass  = sum\\(1 for v in results_stage1.values\\(\\) if v\\)\\\\n\",\n    \"n_total = len\\(results_stage1\\)\\\\n\",\n    \"print\\(\\)\\\\n\",\n    \"print\\(f'\\\\u9636\\\\u6bb51 \\\\u9a8c\\\\u8bc1\\\\u7ed3\\\\u679c: {n_pass}/{n_total} \\\\u901a\\\\u8fc7'\\)\\\\n\"\n]\n\njson.dump\\(nb, open\\('D:/PFE-U/PAR-S-Generator/notebook/pipeline_overview.ipynb', 'w', encoding='utf-8'\\), ensure_ascii=False, indent=1\\)\nprint\\('Notebook updated: cells 3, 13, 37'\\)\nPYEOF)",
